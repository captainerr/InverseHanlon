// Cloudflare Workers config: deploys the built Astro site as static assets.
// Used by Workers Builds (Git integration) — deploy command: `npx wrangler deploy`.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inversehanlon",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
