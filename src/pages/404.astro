---
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <article class="article">
    <header>
      <h1>404 — Not found</h1>
    </header>
    <div class="prose">
      <p>
        This page doesn't exist. Whether that's incompetence or malice is left as an exercise for
        the reader.
      </p>
      <p><a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/`}>← Back to the posts</a></p>
    </div>
  </article>
</Base>
